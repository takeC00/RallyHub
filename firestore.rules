rules_version = '2';

// rallyos プロジェクト共通ルール（正本: RallyMatch/firestore.rules）
// デプロイ: cd ../RallyMatch && firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // ── 共通 ──────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function memberPath(circleId) {
      return /databases/$(database)/documents/circleMembers/$(circleId + '_' + request.auth.uid);
    }

    function circlePath(circleId) {
      return /databases/$(database)/documents/circles/$(circleId);
    }

    function memberDoc(circleId) {
      return get(memberPath(circleId));
    }

    function circleDoc(circleId) {
      return get(circlePath(circleId));
    }

    function isCircleMember(circleId) {
      return isSignedIn() && (
        exists(memberPath(circleId))
        || circleDoc(circleId).data.ownerId == request.auth.uid
        || ('memberIds' in circleDoc(circleId).data
          && request.auth.uid in circleDoc(circleId).data.memberIds)
      );
    }

    function isOwnerOrAdmin(circleId) {
      return isSignedIn() && (
        circleDoc(circleId).data.ownerId == request.auth.uid
        || (exists(memberPath(circleId))
          && memberDoc(circleId).data.role in ['owner', 'admin'])
      );
    }

    function isCircleOwner(circleId) {
      return isSignedIn()
        && circleDoc(circleId).data.ownerId == request.auth.uid;
    }

    function sessionCircleId(sessionId) {
      return get(/databases/$(database)/documents/sessions/$(sessionId)).data.circleId;
    }

    function canDeleteSession(sessionId) {
      return isSessionOwner(sessionId)
        || (sessionCircleId(sessionId) != null
          && isCircleOwner(sessionCircleId(sessionId)));
    }

    function isSelfJoiningCircle() {
      return isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
        && request.auth.uid in request.resource.data.memberIds
        && !('memberIds' in resource.data
          && request.auth.uid in resource.data.memberIds);
    }

    // ── RallyMatch ─────────────────────────────────────

    function isSessionOwner(sessionId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/sessions/$(sessionId)).data.ownerUid == request.auth.uid;
    }

    match /sessions/{sessionId} {
      allow get: if true;
      allow list: if isSignedIn()
        && resource.data.circleId != null
        && isCircleOwner(resource.data.circleId);
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSessionOwner(sessionId);
      allow delete: if canDeleteSession(sessionId);

      match /matches/{matchId} {
        allow get, list: if true;
        allow create, update: if isSessionOwner(sessionId);
        allow delete: if canDeleteSession(sessionId);
      }

      match /sessionPlayers/{playerId} {
        allow get, list: if true;
        allow create, update: if isSessionOwner(sessionId);
        allow delete: if canDeleteSession(sessionId);
      }
    }

    // ── RallyHub / RallyMate 共通コレクション ──────────

    match /users/{userId} {
      allow read, write: if isSelf(userId);
    }

    match /circles/{circleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() == 1
        && request.resource.data.memberIds[0] == request.auth.uid;
      allow update: if isOwnerOrAdmin(circleId)
        || isSelfJoiningCircle()
        || (isCircleMember(circleId)
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['memberIds', 'updatedAt']));
      allow delete: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;
    }

    match /circleMembers/{memberId} {
      allow read: if isSignedIn()
        && (resource == null
          || !('userId' in resource.data)
          || resource.data.userId == request.auth.uid
          || isCircleMember(resource.data.circleId));
      allow create: if isSignedIn()
        && (
          (request.resource.data.memberType == 'registered'
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.role in ['member', 'owner', 'admin'])
          || (request.resource.data.memberType == 'manual'
            && isCircleMember(request.resource.data.circleId)
            && !('userId' in request.resource.data))
        );
      allow update: if isSignedIn()
        && (
          (resource.data.circleId != null
            && get(/databases/$(database)/documents/circles/$(resource.data.circleId)).data.ownerId == request.auth.uid)
          || (isCircleMember(resource.data.circleId)
            && resource.data.memberType == 'manual')
          || (isCircleMember(resource.data.circleId)
            && resource.data.memberType == 'registered'
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['rating', 'level', 'notes', 'updatedAt']))
          || (isCircleMember(resource.data.circleId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating']))
          || (resource.data.userId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userName', 'displayName']))
        );
      allow delete: if isSignedIn()
        && resource.data.circleId != null
        && (
          get(/databases/$(database)/documents/circles/$(resource.data.circleId)).data.ownerId == request.auth.uid
          || (isOwnerOrAdmin(resource.data.circleId) && resource.data.memberType == 'manual')
        );
    }

    match /events/{eventId} {
      allow read: if isSignedIn()
        && isCircleMember(resource.data.circleId);
      allow create: if isSignedIn()
        && isOwnerOrAdmin(request.resource.data.circleId);
      allow update: if isSignedIn()
        && isCircleMember(resource.data.circleId)
        && (
          isOwnerOrAdmin(resource.data.circleId)
          || request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['participantCount', 'absentCount', 'pendingCount', 'isFull', 'updatedAt', 'fullNotifiedAt', 'vacancyNotifiedAt'])
        );
      allow delete: if isSignedIn()
        && isOwnerOrAdmin(resource.data.circleId);
    }

    match /eventParticipants/{participantId} {
      allow read: if isSignedIn()
        && (resource == null
          || resource.data.userId == request.auth.uid
          || isCircleMember(resource.data.circleId));
      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && isCircleMember(request.resource.data.circleId);
      allow delete: if isSignedIn()
        && (resource.data.userId == request.auth.uid
          || (resource.data.circleId != null
            && isCircleOwner(resource.data.circleId)));
    }

    match /eventVisitors/{visitorId} {
      allow read: if isSignedIn()
        && isCircleMember(resource.data.circleId);
      allow create: if isSignedIn()
        && isOwnerOrAdmin(request.resource.data.circleId);
      allow update, delete: if isSignedIn()
        && isOwnerOrAdmin(resource.data.circleId);
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn()
        && isCircleMember(resource.data.circleId);
      allow create: if isSignedIn()
        && isOwnerOrAdmin(request.resource.data.circleId);
      allow update, delete: if isSignedIn()
        && isOwnerOrAdmin(resource.data.circleId);
    }

    // ── RallyMatch 今日だけ参加（Mate 連携） ─────────

    match /circleDayParticipants/{participantId} {
      allow read: if isSignedIn()
        && (resource == null || isCircleMember(resource.data.circleId));
      allow create, update: if isSignedIn()
        && isCircleMember(request.resource.data.circleId)
        && request.resource.data.circleId is string
        && request.resource.data.participantId is string
        && request.resource.data.name is string
        && request.resource.data.dateKey is string;
      allow delete: if isSignedIn()
        && isCircleMember(resource.data.circleId);
    }

    // ── RallyMatch サークル参加者名簿 ─────────────────

    match /circleRoster/{rosterId} {
      allow read: if isSignedIn()
        && (resource == null || isCircleMember(resource.data.circleId));
      allow create: if isSignedIn()
        && isCircleMember(request.resource.data.circleId)
        && request.resource.data.circleId is string
        && request.resource.data.name is string
        && request.resource.data.playerId is string
        && request.resource.data.level is string
        && (!('userId' in request.resource.data)
          || request.resource.data.userId is string);
      allow update, delete: if isSignedIn()
        && isCircleMember(resource.data.circleId);
    }

    // ── RallyMate 本日レート QR スナップショット ─────

    match /ratingSnapshots/{snapshotId} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && isCircleMember(request.resource.data.circleId);
      allow delete: if isSignedIn()
        && isCircleOwner(resource.data.circleId);
    }

    // ── RallyMate ──────────────────────────────────────

    match /matches/{matchId} {
      allow read: if isSignedIn()
        && isCircleMember(resource.data.circleId);
      allow create: if isSignedIn()
        && isCircleMember(request.resource.data.circleId);
      allow update, delete: if isSignedIn()
        && isCircleMember(resource.data.circleId);
    }
  }
}
